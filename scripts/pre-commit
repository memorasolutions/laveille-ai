#!/bin/bash

STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.php')

if [ -z "$STAGED_PHP_FILES" ]; then
    exit 0
fi

echo -e "\033[1mRunning pre-commit checks on staged PHP files...\033[0m"
echo ""

FAILED=0

echo -n "Running Laravel Pint... "
if ./vendor/bin/pint --test $STAGED_PHP_FILES > /dev/null 2>&1; then
    echo -e "\033[32m✓\033[0m"
else
    echo -e "\033[31m✗\033[0m"
    echo ""
    ./vendor/bin/pint --test $STAGED_PHP_FILES
    FAILED=1
fi

echo -n "Running PHPStan... "
if ./vendor/bin/phpstan analyse $STAGED_PHP_FILES --no-progress --memory-limit=512M > /dev/null 2>&1; then
    echo -e "\033[32m✓\033[0m"
else
    echo -e "\033[31m✗\033[0m"
    echo ""
    ./vendor/bin/phpstan analyse $STAGED_PHP_FILES --no-progress --memory-limit=512M
    FAILED=1
fi

echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "\033[32mAll checks passed!\033[0m"
    exit 0
else
    echo -e "\033[31mPre-commit checks failed. Fix the issues above before committing.\033[0m"
    exit 1
fi
