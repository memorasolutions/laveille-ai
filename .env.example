APP_NAME=Laravel
SUPER_ADMIN_EMAIL=stephane@memora.ca
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_CA
APP_TIMEZONE=America/Montreal

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true  # Activer en production (HTTPS obligatoire)

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database  # Utiliser redis en production

CACHE_STORE=database  # Utiliser redis en production
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Reverb (WebSocket)
REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_ENABLED=false
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Horizon
HORIZON_PREFIX=laravel_horizon_
# HORIZON_MEMORY_LIMIT=64

# Telescope (desactiver en production)
TELESCOPE_ENABLED=true
# TELESCOPE_SAME_IP=true

# Backups (spatie/laravel-backup)
BACKUP_NAME="${APP_NAME}"
BACKUP_DISK=local
# BACKUP_NOTIFICATION_MAIL=admin@example.com

# Health checks (spatie/laravel-health)
HEALTH_DISK=local
# HEALTH_OH_DEAR_API_TOKEN=

# Permissions (spatie/laravel-permission)
PERMISSION_CACHE_EXPIRATION_TIME=1440

# Admin
ADMIN_PATH=admin
BACKOFFICE_THEME=backend

# Security
FORCE_HTTPS=false
CSP_ENABLED=false

# Google Analytics (GA4 Consent Mode v2)
GA_MEASUREMENT_ID=
PRIVACY_GA_ENABLED=false

# Sentry (error tracking)
SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Pulse (production monitoring)
# PULSE_ENABLED=true
# PULSE_PATH=pulse

# Scramble (API documentation)
# SCRAMBLE_PATH=docs/api

# Sanctum (API tokens)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1
SANCTUM_TOKEN_EXPIRATION=10080
SANCTUM_TOKEN_PREFIX=core_

# Frontend SPA (si applicable)
FRONTEND_URL=http://localhost:3000

# Response cache (spatie/laravel-responsecache)
# RESPONSE_CACHE_ENABLED=true
# RESPONSE_CACHE_LIFETIME=3600

# Stripe / SaaS (laravel/cashier)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=cad
# CASHIER_CURRENCY_LOCALE=fr_CA
SAAS_CURRENCY=cad
SAAS_TRIAL_DAYS=14

# PWA (Progressive Web App)
PWA_ENABLED=true
PWA_SHORT_NAME="${APP_NAME}"
PWA_DESCRIPTION="Application web progressive"
PWA_THEME_COLOR="#6366f1"
PWA_BACKGROUND_COLOR="#0f172a"

# Scout (recherche)
SCOUT_DRIVER=database
SCOUT_QUEUE=true

# Tenancy (stancl/tenancy)
TENANCY_IDENTIFICATION=domain
TENANCY_HEADER=X-Tenant-ID
# Web Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# OAuth / Social Login (optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=/auth/github/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=/auth/microsoft/callback
MICROSOFT_TENANT_ID=common
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=/auth/facebook/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=/auth/linkedin/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=/auth/x/callback
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=/auth/apple/callback

# Admin Seeder (personnaliser avant premier db:seed)
ADMIN_NAME="Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!
