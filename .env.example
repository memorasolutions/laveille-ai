APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_CA
APP_TIMEZONE=America/Montreal

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Horizon
HORIZON_PREFIX=laravel_horizon_
# HORIZON_MEMORY_LIMIT=64

# Telescope
TELESCOPE_ENABLED=true
# TELESCOPE_SAME_IP=true

# Backups (spatie/laravel-backup)
BACKUP_NAME="${APP_NAME}"
BACKUP_DISK=local
# BACKUP_NOTIFICATION_MAIL=admin@example.com

# Health checks (spatie/laravel-health)
HEALTH_DISK=local
# HEALTH_OH_DEAR_API_TOKEN=

# Permissions (spatie/laravel-permission)
PERMISSION_CACHE_EXPIRATION_TIME=1440

# Filament
FILAMENT_PATH=admin

# Security
FORCE_HTTPS=false
CSP_ENABLED=false

# Sentry (error tracking)
SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Pulse (production monitoring)
# PULSE_ENABLED=true
# PULSE_PATH=pulse

# Scramble (API documentation)
# SCRAMBLE_PATH=docs/api

# Sanctum (API tokens)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1
SANCTUM_TOKEN_EXPIRATION=10080
SANCTUM_TOKEN_PREFIX=core_

# Frontend SPA (si applicable)
FRONTEND_URL=http://localhost:3000

# Response cache (spatie/laravel-responsecache)
# RESPONSE_CACHE_ENABLED=true
# RESPONSE_CACHE_LIFETIME=3600
